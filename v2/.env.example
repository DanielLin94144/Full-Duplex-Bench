# Full-Duplex Bench 2.0 - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys (Required)
# =============================================================================
OPENAI_API_KEY="your_openai_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# =============================================================================
# Server Ports
# =============================================================================
# Orchestrator WebSocket signaling port
SIGNAL_PORT=9100

# OpenAI token server port (for ephemeral Realtime session tokens)
TOKEN_SERVER_PORT=3002

# =============================================================================
# Model Configuration
# =============================================================================
# OpenAI Realtime model name
OPENAI_REALTIME_MODEL="gpt-realtime-2025-08-28"

# Gemini model for evaluation (LLM-as-a-judge)
GEMINI_MODEL="gemini-2.5-flash"

# =============================================================================
# Voice Configuration
# =============================================================================
# Default voice for Role A (Examiner) - Options: alloy, echo, fable, onyx, nova, shimmer
VOICE_A="echo"

# Default voice for Role B (Examinee) - Options: alloy, echo, fable, onyx, nova, shimmer
VOICE_B="shimmer"

# =============================================================================
# Recording & Output
# =============================================================================
# Directory for recording outputs
RECORD_DIR="outputs"

# =============================================================================
# Timing & Duration
# =============================================================================
# Default conversation duration in seconds
DEFAULT_DURATION=120

# Maximum audio processing time for ASR (seconds)
MAX_ASR_TIME=120

# =============================================================================
# External Service URLs
# =============================================================================
# OpenAI token server URL (usually local)
OPENAI_TOKEN_SERVER="http://localhost:3002"

# Freeze-Omni server URL (if using Freeze-Omni adapter)
FREEZE_OMNI_URL="https://localhost:8081"

# Moshi server URL (if using Moshi adapter)
MOSHI_URL="ws://localhost:8998/api/chat"

# =============================================================================
# Audio Configuration (Advanced - usually no need to change)
# =============================================================================
# Wire sample rate (orchestrator <-> adapters)
WIRE_SAMPLE_RATE=48000

# Freeze-Omni uplink sample rate
FO_UPLINK_SAMPLE_RATE=16000

# Freeze-Omni downlink sample rate
FO_DOWNLINK_SAMPLE_RATE=24000

# Moshi sample rate
MOSHI_SAMPLE_RATE=24000

# =============================================================================
# System Prompts
# =============================================================================
# Default system prompt for the examinee (Role B)
EXAMINEE_SYSTEM_PROMPT="You are a helpful AI assistant. Only speak English throughout the conversation."
